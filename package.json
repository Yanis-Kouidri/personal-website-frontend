{
  "name": "portfolio-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "tsc --noEmit && vite build",
    "check": "tsc --noEmit",
    "check:strict": "tsc --noEmit --strict",
    "lint": "biome check .",
    "lint:fix": "biome check --write . ",
    "format": "biome format .",
    "format:fix": "biome format --write . ",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,jsx,tsx}": [
      "biome check --write --no-errors-on-unmatched",
      "vitest related --run"
    ]
  },
  "dependencies": {
    "@types/qs": "^6.15.1",
    "axios": "^1.17.0",
    "lucide-react": "^1.18.0",
    "qs": "^6.15.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "styled-components": "^6.4.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "baseline-browser-mapping": "^2.10.37",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.7",
    "retire": "^5.4.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
